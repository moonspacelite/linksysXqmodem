#!/bin/sh

LOG_TAG='linksysxqmodem-lpac'
log() { logger -t "${LOG_TAG}" -- "$*"; }

ensure_lpac_option() {
	option="$1"
	value="$2"

	if ! uci -q get "lpac-esim.main.${option}" >/dev/null 2>&1; then
		uci -q set "lpac-esim.main.${option}=${value}"
	fi
}

set_lpac_option() {
	option="$1"
	value="$2"

	uci -q set "lpac-esim.main.${option}=${value}"
}

log "initializing LPAC defaults"

for svc in modemmanager ModemManager; do
	if [ -x "/etc/init.d/${svc}" ]; then
		"/etc/init.d/${svc}" stop >/dev/null 2>&1 || true
		"/etc/init.d/${svc}" disable >/dev/null 2>&1 || true
	fi
done
killall ModemManager mmcli 2>/dev/null || true
rm -f /etc/rc.d/S*modemmanager /etc/rc.d/K*modemmanager /etc/rc.d/S*ModemManager /etc/rc.d/K*ModemManager 2>/dev/null || true
log "ModemManager disabled; QModem owns MBIM"

uci -q get lpac-esim.main >/dev/null 2>&1 || uci -q set lpac-esim.main='lpac-esim'

set_lpac_option apdu_backend 'mbim'
set_lpac_option http_backend 'curl'
set_lpac_option qmi_device '/dev/cdc-wdm0'
set_lpac_option qmi_sim_slot '1'
set_lpac_option sim_slot '1'
set_lpac_option at_device '/dev/ttyUSB2'
set_lpac_option mbim_device '/dev/cdc-wdm0'
set_lpac_option mbim_proxy '1'
set_lpac_option mbim_skip_slot_mapping '1'
set_lpac_option mbim_uim_slot '2'
set_lpac_option custom_isd_r_aid 'A0000005591010FFFFFFFF8900000100'
set_lpac_option reboot_method 'script'
set_lpac_option modem_iface '1_1'
ensure_lpac_option apdu_debug '0'
ensure_lpac_option http_debug '0'
ensure_lpac_option at_debug '0'
ensure_lpac_option telegram_enabled "${LPAC_ESIM_TELEGRAM_ENABLED:-0}"
ensure_lpac_option telegram_bot_token ''
ensure_lpac_option telegram_allowed_chat_id ''
ensure_lpac_option telegram_poll_interval '2'
ensure_lpac_option telegram_debug '0'

uci -q commit lpac-esim

uci -q get lpac.global >/dev/null 2>&1 || uci -q set lpac.global='global'
uci -q set lpac.global.apdu_backend='mbim'
uci -q set lpac.global.http_backend='curl'
uci -q set lpac.global.custom_isd_r_aid='A0000005591010FFFFFFFF8900000100'
uci -q get lpac.mbim >/dev/null 2>&1 || uci -q set lpac.mbim='mbim'
uci -q set lpac.mbim.device='/dev/cdc-wdm0'
uci -q set lpac.mbim.proxy='1'
uci -q set lpac.mbim.skip_slot_mapping='1'
uci -q set lpac.mbim.uim_slot='2'
uci -q get lpac.uqmi >/dev/null 2>&1 || uci -q set lpac.uqmi='uqmi'
uci -q set lpac.uqmi.device='/dev/cdc-wdm0'
uci -q set lpac.uqmi.debug='0'
uci -q get lpac.at >/dev/null 2>&1 || uci -q set lpac.at='at'
uci -q set lpac.at.device='/dev/ttyUSB2'
uci -q commit lpac

if [ -x /usr/libexec/mbim-proxy ]; then
	log "mbim-proxy present at /usr/libexec/mbim-proxy"
else
	log "WARNING: /usr/libexec/mbim-proxy missing; libmbim must be installed for safe LPAC MBIM access"
fi

log "LPAC defaults set: backend=mbim device=/dev/cdc-wdm0 proxy=1 skip_slot=1 uim_slot=2 at=/dev/ttyUSB2 iface=1_1"

if [ -x /etc/init.d/esim-telegram-bot ]; then
	/etc/init.d/esim-telegram-bot enable >/dev/null 2>&1 || true
	log "Telegram eSIM bot service enabled; it starts only after token/config is set"
fi

if [ -x /etc/init.d/mount-debugfs ]; then
	/etc/init.d/mount-debugfs enable >/dev/null 2>&1 || true
	/etc/init.d/mount-debugfs start >/dev/null 2>&1 || true
	log "debugfs mount service enabled"
fi

rm -f /tmp/luci-indexcache /tmp/luci-modulecache 2>/dev/null
rm -rf /tmp/luci-modulecache/ 2>/dev/null
/etc/init.d/rpcd restart >/dev/null 2>&1 || true

log "LPAC first-boot setup done"
exit 0
