#!/bin/sh
# Telegram-friendly HYFE manual claim bridge.
#
# This wraps the upstream /usr/lib/hyfetrial shell libraries, while exposing
# the interactive CLI flow as Telegram-friendly steps.

set -eu

HYFE_LIB_DIR="${HYFE_LIB_DIR:-/usr/lib/hyfetrial}"
STATE_ROOT="${HYFE_TG_STATE_ROOT:-/tmp/lpac-esim/hyfe}"

json_out() {
	jq -nc "$@"
}

fail_json() {
	msg="$1"
	json_out --arg error "$msg" '{ok:false,error:$error}'
	exit 1
}

need_file() {
	[ -f "$1" ] || fail_json "missing HYFE library: $1"
}

load_libs() {
	need_file "$HYFE_LIB_DIR/common.sh"
	need_file "$HYFE_LIB_DIR/config.sh"
	need_file "$HYFE_LIB_DIR/api.sh"
	need_file "$HYFE_LIB_DIR/captcha.sh"
	. "$HYFE_LIB_DIR/common.sh"
	. "$HYFE_LIB_DIR/config.sh"
	. "$HYFE_LIB_DIR/api.sh"
	. "$HYFE_LIB_DIR/captcha.sh"
	need_file "$HYFE_LIB_DIR/otp.sh"
	. "$HYFE_LIB_DIR/otp.sh"

	CONFIG_FILE="${CONFIG_FILE:-$(config_default_path)}"
	if [ -r "$CONFIG_FILE" ]; then
		# shellcheck disable=SC1090
		. "$CONFIG_FILE"
	fi
}

resolve_captcha_key() {
	mode="$1"
	[ "$mode" = "manual" ] && return 0
	HYFE_CAPTCHA_KEY=$(captcha_resolve_key "$mode" 2>/dev/null || true)
	[ -n "$HYFE_CAPTCHA_KEY" ] || fail_json "API key captcha untuk $mode belum diset"
	export HYFE_CAPTCHA_KEY
}

resolve_imap_for_email() {
	email="$1"
	i=1
	if [ -z "${HYFE_IMAP_USER:-}" ]; then
		HYFE_IMAP_USER="$email"
	fi
	while [ "$i" -le 9 ]; do
		eval "slot_email=\${HYFE_EMAIL_$i:-}"
		if [ "$slot_email" = "$email" ]; then
			eval "slot_pass=\${HYFE_IMAP_PASS_$i:-}"
			if [ -n "$slot_pass" ]; then
				HYFE_IMAP_USER="$email"
				HYFE_IMAP_PASS="$slot_pass"
			fi
			break
		fi
		i=$((i + 1))
	done
	export HYFE_IMAP_USER HYFE_IMAP_PASS
}

normalize_wa() {
	wa=$(printf '%s' "$1" | tr -d ' +().-')
	case "$wa" in
		+62*) wa=${wa#+62} ;;
		62*)  wa=${wa#62} ;;
		0*)   wa=${wa#0} ;;
	esac
	case "$wa" in
		*[!0-9]*|'') return 1 ;;
	esac
	[ "${#wa}" -ge 8 ] && [ "${#wa}" -le 12 ] || return 1
	printf '%s' "$wa"
}

normalize_msisdn() {
	n=$(printf '%s' "$1" | tr -d ' +().-')
	case "$n" in
		0*) n="62${n#0}" ;;
		8*) n="62$n" ;;
	esac
	case "$n" in
		62[0-9]*) ;;
		*) return 1 ;;
	esac
	[ "${#n}" -ge 10 ] && [ "${#n}" -le 15 ] || return 1
	printf '%s' "$n"
}

normalize_eid() {
	eid=$(printf '%s' "$1" | tr -d ' :-')
	case "$eid" in
		*[!0-9]*|'') return 1 ;;
	esac
	[ "${#eid}" -eq 32 ] || return 1
	printf '%s' "$eid"
}

msisdn_pattern() {
	ms="$1"
	len=${#ms}
	if [ "$len" -gt 5 ]; then
		printf '%s' "$ms" | tail -c 5
	else
		printf '%s' "$ms"
	fi
}

list_numbers() {
	load_libs
	require_cmd curl jq

	pattern=$(printf '%s' "${1:-}" | tr -d ' ')
	case "$pattern" in
		""|*[!0-9]*) [ -z "$pattern" ] || fail_json "Pola harus 1-5 digit angka" ;;
	esac
	[ "${#pattern}" -le 5 ] || fail_json "Pola maksimal 5 digit"

	# Inisialisasi cookie jar — normalnya dilakukan oleh hyfe_init() di CLI mode,
	# tapi list_numbers dipanggil langsung tanpa hyfe_init sehingga HYFE_COOKIES
	# tidak ter-set dan curl gagal membaca/menulis sesi auth.
	HYFE_COOKIES="${HYFE_COOKIES:-${TMPDIR:-/tmp}/hyfe-cookies-tg.$$}"
	export HYFE_COOKIES
	: > "$HYFE_COOKIES"

	api_auth
	api_session
	url_page=1
	if [ -n "$pattern" ]; then body_page=1; else body_page=$(( ( $(date +%s) % 496 ) + 5 )); fi
	body=$(api_find_msisdn "$url_page" "$body_page" "$pattern") || fail_json "gagal mengambil daftar nomor"
	printf '%s' "$body" | jq -r '
		.result.data.noMsisdn[]? |
		select(.msisdn and .encrypt) |
		[.msisdn, .encrypt] | @tsv
	' | head -n 20
}

find_msisdn_encrypt() {
	target="$1"
	pattern="$(msisdn_pattern "$target")"
	url_page=1
	body_page=1
	body=$(api_find_msisdn "$url_page" "$body_page" "$pattern") || return 1
	line=$(printf '%s\n' "$body" | jq -r --arg target "$target" '
		.result.data.noMsisdn[]? |
		select(.msisdn == $target) |
		[.msisdn, .encrypt] | @tsv
	' | head -n1)
	if [ -z "$line" ]; then
		return 1
	fi
	SELECTED_MSISDN=$(printf '%s' "$line" | cut -f1)
	SELECTED_ENCRYPT=$(printf '%s' "$line" | cut -f2-)
	[ -n "$SELECTED_ENCRYPT" ] && [ "$SELECTED_ENCRYPT" != "null" ]
}

write_state_value() {
	printf '%s' "$2" > "$state_dir/$1"
	chmod 600 "$state_dir/$1" 2>/dev/null || :
}

read_state_value() {
	cat "$state_dir/$1" 2>/dev/null || true
}

start_manual() {
	load_libs
	require_cmd curl jq

	name="$1"
	wa="$(normalize_wa "$2")" || fail_json "Nomor WhatsApp tidak valid"
	email="$3"
	target="$(normalize_msisdn "$4")" || fail_json "Nomor HYFE target tidak valid"
	eid="$(normalize_eid "$5")" || fail_json "EID harus 32 digit"
	selected_encrypt="${6:-}"
	case "$name" in *'|'*|'') fail_json "Nama tidak valid" ;; esac
	case "$email" in *@*.*) ;; *) fail_json "Email tidak valid" ;; esac
	otp_mode="${HYFE_OTP_MODE:-manual}"
	case "$otp_mode" in manual|imap) ;; *) fail_json "HYFE_OTP_MODE tidak dikenal: $otp_mode" ;; esac

	mkdir -p "$STATE_ROOT"
	sid="$(gen_uuid 2>/dev/null || date +%s)-$$"
	state_dir="$STATE_ROOT/$sid"
	mkdir -p "$state_dir"
	chmod 700 "$state_dir" 2>/dev/null || :
	HYFE_COOKIES="$state_dir/cookies.txt"
	export HYFE_COOKIES
	: > "$HYFE_COOKIES"

	api_auth
	api_session
	if [ -n "$selected_encrypt" ]; then
		SELECTED_MSISDN="$target"
		SELECTED_ENCRYPT="$selected_encrypt"
	else
		find_msisdn_encrypt "$target" || fail_json "Nomor HYFE $target tidak tersedia pada listing saat ini"
	fi

	access_token=$(api_tnc_token) || fail_json "tncToken gagal"
	[ -n "$access_token" ] || fail_json "tncToken kosong"
	optin_body=$(api_tnc_optin "$email" "$access_token") || fail_json "optIn gagal"
	consent_id=$(printf '%s' "$optin_body" | jq -r '.result.data.consentId // empty')
	[ -n "$consent_id" ] || fail_json "consentId tidak ditemukan"
	if [ "$otp_mode" = "imap" ]; then
		resolve_imap_for_email "$email"
		otp_capture_baseline >/dev/null 2>&1 || fail_json "imap baseline gagal"
	fi
	api_send_otp "$email" "$name" >/dev/null || fail_json "send OTP gagal"

	write_state_value name "$name"
	write_state_value wa "$wa"
	write_state_value email "$email"
	write_state_value eid "$eid"
	write_state_value msisdn "$SELECTED_MSISDN"
	write_state_value encrypt "$SELECTED_ENCRYPT"
	write_state_value consent_id "$consent_id"
	write_state_value tnc_token "$access_token"
	write_state_value token "$HYFE_TOKEN"
	write_state_value csrf "$HYFE_CSRF"
	write_state_value otp_mode "$otp_mode"
	write_state_value imap_baseline "${HYFE_IMAP_BASELINE_UID:-}"

	json_out \
		--arg sid "$sid" \
		--arg msisdn "$SELECTED_MSISDN" \
		--arg email "$email" \
		--arg otp_mode "$otp_mode" \
		'{ok:true,sid:$sid,msisdn:$msisdn,email:$email,otp_mode:$otp_mode}'
}

poll_otp() {
	load_libs
	require_cmd curl jq

	sid="$1"
	case "$sid" in *[!A-Za-z0-9._-]*|'') fail_json "sid tidak valid" ;; esac
	state_dir="$STATE_ROOT/$sid"
	[ -d "$state_dir" ] || fail_json "sesi klaim tidak ditemukan/expired"

	email=$(read_state_value email)
	HYFE_OTP_MODE=$(read_state_value otp_mode)
	[ -n "$HYFE_OTP_MODE" ] || HYFE_OTP_MODE="${HYFE_OTP_MODE:-manual}"
	[ "$HYFE_OTP_MODE" = "imap" ] || fail_json "sesi ini bukan OTP IMAP"
	HYFE_IMAP_BASELINE_UID=$(read_state_value imap_baseline)
	export HYFE_OTP_MODE HYFE_IMAP_BASELINE_UID
	resolve_imap_for_email "$email"

	otp=$(otp_get) || fail_json "OTP IMAP gagal/timeout"
	otp=$(printf '%s' "$otp" | tr -d '[:space:]' | tr '[:lower:]' '[:upper:]')
	case "$otp" in *[!A-Z0-9]*|'') fail_json "OTP IMAP tidak valid" ;; esac
	[ "${#otp}" -eq 6 ] || fail_json "OTP IMAP harus 6 karakter"
	json_out --arg otp "$otp" '{ok:true,otp:$otp}'
}

extract_lpa_from_text() {
	if [ "$#" -gt 0 ]; then
		raw="$1"
	else
		raw=$(cat)
	fi
	printf '%s' "$raw" \
		| tr '\r\n' '  ' \
		| sed \
			-e 's/= //g' \
			-e 's/=3D/=/g' \
			-e 's/=24/$/g' \
			-e 's/=2F/\//g' \
			-e 's/=3A/:/g' \
			-e 's/=2B/+/g' \
			-e 's/=3B/;/g' \
			-e 's/=20/ /g' \
			-e 's/&amp;/\&/g' \
			-e 's/<[^>]*>/ /g' \
		| awk '{
			line=$0
			if (match(line, /LPA:1\$[^[:space:]<>\"]+/)) {
				token=substr(line, RSTART, RLENGTH)
				gsub(/[),;]+$/, "", token)
				print token
				exit
			}
		}'
}

capture_lpa_email_baseline() {
	email="$1"
	resolve_imap_for_email "$email" >/dev/null 2>&1 || true
	[ -n "${HYFE_IMAP_URL:-}" ] || return 1
	[ -n "${HYFE_IMAP_USER:-}" ] || return 1
	[ -n "${HYFE_IMAP_PASS:-}" ] || return 1
	_otp_imap_common_prep >/dev/null 2>&1 || return 1
	_otp_imap_latest_uid 2>/dev/null || printf '0'
}

poll_lpa_email() {
	email="$1"
	baseline_max_uid="${2:-}"
	resolve_imap_for_email "$email" >/dev/null 2>&1 || true
	[ -n "${HYFE_IMAP_URL:-}" ] || return 1
	[ -n "${HYFE_IMAP_USER:-}" ] || return 1
	[ -n "${HYFE_IMAP_PASS:-}" ] || return 1
	_otp_imap_common_prep || return 1

	[ -n "$baseline_max_uid" ] || baseline_max_uid=$(_otp_imap_latest_uid 2>/dev/null || printf '0')
	[ -n "$baseline_max_uid" ] || baseline_max_uid=0
	timeout="${HYFE_LPA_TIMEOUT:-180}"
	elapsed=0
	log_info "imap: menunggu email LPA HYFE (timeout ${timeout}s)"

	while [ "$elapsed" -lt "$timeout" ]; do
		if ! search_resp=$(_otp_imap_search_all_uids); then
			sleep 5
			elapsed=$((elapsed + 5))
			continue
		fi
		ids=$(printf '%s' "$search_resp" \
			| awk -v min_uid="$baseline_max_uid" '/\* SEARCH/{for (i=3;i<=NF;i++) { gsub(/[^0-9]/, "", $i); if (($i+0) > min_uid) print $i+0 }}')
		if [ -n "$ids" ]; then
			recent_ids=$(printf '%s\n' "$ids" \
				| tail -n 20 \
				| awk '{a[NR]=$0} END{for (i=NR;i>=1;i--) print a[i]}')
			for uid in $recent_ids; do
				body=$(_otp_imap_fetch_uid "$uid") || continue
				[ -n "$body" ] || continue
				lpa=$(extract_lpa_from_text "$body" | head -n 1)
				if [ -n "$lpa" ]; then
					log_info "imap: LPA string ditemukan di email"
					printf '%s' "$lpa"
					return 0
				fi
			done
		fi
		sleep 5
		elapsed=$((elapsed + 5))
	done
	log_warn "imap: timeout, LPA HYFE belum ditemukan di email"
	return 1
}

finish_claim() {
	load_libs
	require_cmd curl jq

	sid="$1"
	otp=$(printf '%s' "$2" | tr -d '[:space:]' | tr '[:lower:]' '[:upper:]')
	mode="${3:-manual}"
	manual_token="${4:-}"
	case "$sid" in *[!A-Za-z0-9._-]*|'') fail_json "sid tidak valid" ;; esac
	case "$otp" in *[!A-Z0-9]*|'') fail_json "OTP tidak valid" ;; esac
	[ "${#otp}" -eq 6 ] || fail_json "OTP harus 6 karakter"
	case "$mode" in
		manual|nextcaptcha|2captcha|anticaptcha|capsolver) ;;
		*) fail_json "mode captcha tidak dikenal: $mode" ;;
	esac

	state_dir="$STATE_ROOT/$sid"
	[ -d "$state_dir" ] || fail_json "sesi klaim tidak ditemukan/expired"
	HYFE_COOKIES="$state_dir/cookies.txt"
	export HYFE_COOKIES
	[ -f "$HYFE_COOKIES" ] || fail_json "cookie sesi klaim tidak ditemukan"

	name=$(read_state_value name)
	wa=$(read_state_value wa)
	email=$(read_state_value email)
	eid=$(read_state_value eid)
	msisdn=$(read_state_value msisdn)
	encrypt=$(read_state_value encrypt)
	consent_id=$(read_state_value consent_id)
	tnc_token=$(read_state_value tnc_token)
	HYFE_TOKEN=$(read_state_value token)
	HYFE_CSRF=$(read_state_value csrf)
	export HYFE_TOKEN HYFE_CSRF

	HYFE_CAPTCHA_MODE="$mode"
	export HYFE_CAPTCHA_MODE
	if [ "$mode" = "manual" ]; then
		recap="$manual_token"
		[ -n "$recap" ] || fail_json "Token reCAPTCHA kosong"
	else
		resolve_captcha_key "$mode"
		recap=$(captcha_solve) || fail_json "captcha $mode gagal"
		[ -n "$recap" ] || fail_json "captcha $mode mengembalikan token kosong"
	fi

	lpa_baseline=$(capture_lpa_email_baseline "$email" 2>/dev/null || true)
	resp=$(api_validate_submit "$recap" "$otp" "$consent_id" "$encrypt" "$eid" "$name" "$wa" "$email" "$tnc_token") \
		|| fail_json "validateAndSubmit gagal"
	sc=$(printf '%s' "$resp" | jq -r '.statusCode // empty')
	if [ "$sc" != "200" ]; then
		err=$(printf '%s' "$resp" | jq -r '.result.data.result.resultDesc // .statusMessage // .message // "submit gagal"')
		fail_json "$err"
	fi

	lpa=$(printf '%s' "$resp" | jq -r '
		.. | objects |
		(.activationCode? // .lpa? // .lpaString? // .qrCode? // .matchingId? // empty)
	' | awk '/^LPA:/{print; exit}')
	lpa_source="response"
	if [ -z "$lpa" ]; then
		lpa_source="email"
		lpa=$(poll_lpa_email "$email" "$lpa_baseline" 2>/dev/null || true)
	fi
	[ -n "$lpa" ] || lpa_source="empty"
	rm -rf "$state_dir"
	json_out \
		--arg msisdn "$msisdn" \
		--arg lpa "$lpa" \
		--arg lpa_source "$lpa_source" \
		--argjson raw "$resp" \
	'{ok:true,msisdn:$msisdn,lpa:$lpa,lpa_source:$lpa_source,raw:$raw}'
}

set_captcha_config() {
	load_libs
	mode="$1"
	key="${2:-}"
	timeout="${3:-180}"
	case "$mode" in
		manual|nextcaptcha|2captcha|anticaptcha|capsolver) ;;
		*) fail_json "mode captcha tidak dikenal: $mode" ;;
	esac
	CONFIG_FILE="${CONFIG_FILE:-$(config_default_path)}"
	config_set "$CONFIG_FILE" HYFE_CAPTCHA_MODE "$mode" || fail_json "gagal simpan HYFE_CAPTCHA_MODE"
	if [ "$mode" != "manual" ]; then
		[ -n "$key" ] || fail_json "API key $mode kosong"
		uc=$(printf '%s' "$mode" | tr '[:lower:]' '[:upper:]')
		config_set "$CONFIG_FILE" "HYFE_CAPTCHA_KEY_$uc" "$key" || fail_json "gagal simpan API key $mode"
	fi
	config_set "$CONFIG_FILE" HYFE_CAPTCHA_TIMEOUT "$timeout" || true
	json_out --arg mode "$mode" '{ok:true,mode:$mode}'
}

show_captcha_config() {
	load_libs
	mode="${HYFE_CAPTCHA_MODE:-manual}"
	timeout="${HYFE_CAPTCHA_TIMEOUT:-180}"
	key=""
	if [ "$mode" != "manual" ]; then
		key=$(captcha_resolve_key "$mode" 2>/dev/null || true)
	fi
	json_out --arg mode "$mode" --arg timeout "$timeout" --arg has_key "$([ -n "$key" ] && printf 1 || printf 0)" \
		'{ok:true,mode:$mode,timeout:$timeout,has_key:($has_key=="1")}'
}

set_config_value() {
	load_libs
	key="$1"
	value="${2:-}"
	case "$key" in
		HYFE_CAPTCHA_MODE|HYFE_CAPTCHA_TIMEOUT|HYFE_OTP_MODE|HYFE_IMAP_URL|HYFE_IMAP_FOLDER|HYFE_IMAP_SUBJECT|HYFE_IMAP_TIMEOUT|HYFE_LPA_TIMEOUT) ;;
		HYFE_CAPTCHA_KEY_NEXTCAPTCHA|HYFE_CAPTCHA_KEY_2CAPTCHA|HYFE_CAPTCHA_KEY_ANTICAPTCHA|HYFE_CAPTCHA_KEY_CAPSOLVER) ;;
		HYFE_EMAIL_[1-9]|HYFE_IMAP_PASS_[1-9]|HYFE_EID_[1-9]) ;;
		*) fail_json "key config tidak diizinkan: $key" ;;
	esac
	CONFIG_FILE="${CONFIG_FILE:-$(config_default_path)}"
	config_set "$CONFIG_FILE" "$key" "$value" || fail_json "gagal simpan $key"
	json_out --arg key "$key" '{ok:true,key:$key}'
}

show_config() {
	load_libs
	CONFIG_FILE="${CONFIG_FILE:-$(config_default_path)}"
	if [ ! -f "$CONFIG_FILE" ]; then
		config_ensure "$CONFIG_FILE" || fail_json "gagal membuat config"
	fi
	config_show "$CONFIG_FILE"
}

cmd="${1:-}"
case "$cmd" in
	random-name)
		load_libs
		random_indo_name
		;;
	random-wa)
		load_libs
		random_wa_local
		;;
	list-numbers)
		shift
		list_numbers "${1:-}"
		;;
	start-manual)
		[ "$#" -eq 6 ] || [ "$#" -eq 7 ] || fail_json "usage: start-manual <name> <wa> <email> <msisdn> <eid> [encrypt]"
		shift
		start_manual "$@"
		;;
	poll-otp)
		[ "$#" -eq 2 ] || fail_json "usage: poll-otp <sid>"
		shift
		poll_otp "$@"
		;;
	finish)
		[ "$#" -ge 4 ] || fail_json "usage: finish <sid> <otp> <captcha-mode> [manual-token]"
		shift
		finish_claim "$@"
		;;
	finish-manual)
		[ "$#" -eq 4 ] || fail_json "usage: finish-manual <sid> <otp> <recaptcha-token>"
		shift
		finish_claim "$1" "$2" manual "$3"
		;;
	set-captcha)
		[ "$#" -ge 2 ] || fail_json "usage: set-captcha <mode> [api-key] [timeout]"
		shift
		set_captcha_config "$@"
		;;
	show-captcha)
		show_captcha_config
		;;
	set-config)
		[ "$#" -eq 3 ] || fail_json "usage: set-config <KEY> <VALUE>"
		shift
		set_config_value "$@"
		;;
	show-config)
		show_config
		;;
	*)
		fail_json "unknown command: $cmd"
		;;
esac
